# SSH config managed by chezmoi
# Actual keys are per-machine and NOT managed by chezmoi (see .chezmoiignore)

{{ if eq .profile "personal" -}}
# Forward local SSH agent when hopping to home Mac Studio
Host studio
    ForwardAgent yes

{{- end }}

{{ if eq .profile "work" -}}
# Work GitHub (default for health checks and .chezmoiexternal.toml)
Host github.com
    HostName github.com
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/evanweible-wf.id_ed25519
    User git
    AddKeysToAgent yes
    UseKeychain yes

# Personal GitHub (used via git URL rewriting for personal repos)
Host github.com-personal
    HostName github.com
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes
    User git
    AddKeysToAgent yes
    UseKeychain yes
{{- else -}}
# Personal GitHub (default)
Host github.com
    HostName github.com
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    User git
    AddKeysToAgent yes
    UseKeychain yes
{{- end }}
