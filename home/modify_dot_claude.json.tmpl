#!/bin/bash

# Modify script to merge MCP servers into ~/.claude.json without
# overwriting other settings that Claude Code manages dynamically.

set -euo pipefail

WK_MCP_SERVER_NAMES='["atlassian","aws-cost-explorer","aws-pricing","github","skynet"]'

# Define the MCP servers we want to ensure exist on work profile
read -r -d '' DESIRED_MCP_SERVERS << 'EOF' || true
{
  "atlassian": {
    "command": "{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp",
    "args": ["atlassian"]
  },
  "github": {
    "command": "{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp",
    "args": ["github"]
  },
  "skynet": {
    "command": "{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp",
    "args": ["skynet"]
  }
}
EOF

# MCP servers to include on all profiles
read -r -d '' COMMON_MCP_SERVERS << 'EOF' || true
{
  "excalidraw": {
    "command": "node",
    "args": ["/Users/evanweible/Developer/public/excalidraw-mcp/dist/index.js", "--stdio"]
  }
}
EOF

# Read existing file from stdin (chezmoi passes current contents)
EXISTING=$(cat)

# If file is empty or doesn't exist, start with empty object
if [[ -z "$EXISTING" ]]; then
  EXISTING='{}'
fi

{{- if eq .profile "work" }}
# Work profile: merge common + wk-mcp servers into mcpServers.
echo "$EXISTING" | jq \
  --argjson common "$COMMON_MCP_SERVERS" \
  --argjson servers "$DESIRED_MCP_SERVERS" '
  .mcpServers = ((.mcpServers // {}) * $common * $servers)
'
{{- else }}
# Non-work profiles: merge common servers, remove wk-mcp servers if present.
echo "$EXISTING" | jq \
  --argjson common "$COMMON_MCP_SERVERS" \
  --argjson names "$WK_MCP_SERVER_NAMES" '
  .mcpServers = (
    ((.mcpServers // {}) * $common) as $m
    | reduce $names[] as $name ($m; del(.[$name]))
  )
'
{{- end }}
