{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@plannotator/opencode@latest"],
  "permission": {
    "bash": {
      "bash -n *": "allow",
      "gh api repos*": "allow"
    }
  },
  "mcp": {
{{- if eq .profile "work" }}
    "github": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "github"],
      "enabled": true
    },
    "aws-pricing": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "aws-pricing"],
      "enabled": true
    },
    "aws-cost-explorer": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "aws-cost-explorer"],
      "enabled": true
    },
    "atlassian": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "atlassian"],
      "enabled": true
    },
    "task": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "task"],
      "enabled": true
    },
    "monday": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "monday"],
      "enabled": true
    },
    "skynet": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.wk/bin/wk-mcp", "skynet"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    },
    "launchdarkly": {
      "type": "remote",
      "url": "https://mcp.launchdarkly.com/mcp/fm",
      "enabled": true
    }
{{- end }}
  }
}
